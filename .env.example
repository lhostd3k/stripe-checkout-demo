# ─────────────────────────────────────────────────────────────────────────────
# .env.example
#
# Copy this file to ".env" and fill in your real values.
# NEVER commit your real .env file to GitHub.
# ─────────────────────────────────────────────────────────────────────────────

# Your Stripe SECRET key (starts with sk_test_ for test mode)
# Found at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_SECRET_KEY

# The full URL where your app is hosted (no trailing slash)
# LOCAL development:  http://localhost:3000
# Render.com:         https://your-app-name.onrender.com
YOUR_DOMAIN=http://localhost:3000

# The port the server listens on
# Render.com sets this automatically — do NOT change it on Render
PORT=3000
